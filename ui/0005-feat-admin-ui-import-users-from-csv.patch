diff --git a/ui/src/util/UserCsvImport.test.ts b/ui/src/util/UserCsvImport.test.ts
new file mode 100644
index 00000000..3938dea7
--- /dev/null
+++ b/ui/src/util/UserCsvImport.test.ts
@@ -0,0 +1,44 @@
+import { describe, expect, it } from "vitest";
+
+import User from "@/types/User";
+import { parseUserCsvImport } from "./UserCsvImport";
+
+describe("parseUserCsvImport", () => {
+  it("parses create-user fields and groups", () => {
+    const rows = parseUserCsvImport(
+      [
+        "email,firstname,lastname,role,password,sendInvitation,authProviderId,organizationId,groupNames,groupIds",
+        '"john@example.com",John,Doe,spaceAdmin,Sea!surf1ng,no,,,"Engineering; Support","11111111-1111-4111-8111-111111111111"',
+      ].join("\n"),
+    );
+
+    expect(rows).toHaveLength(1);
+    expect(rows[0].email).toBe("john@example.com");
+    expect(rows[0].firstname).toBe("John");
+    expect(rows[0].lastname).toBe("Doe");
+    expect(rows[0].role).toBe(User.UserRoleSpaceAdmin);
+    expect(rows[0].password).toBe("Sea!surf1ng");
+    expect(rows[0].sendInvitation).toBe(false);
+    expect(rows[0].groupNames).toEqual(["Engineering", "Support"]);
+    expect(rows[0].groupIds).toEqual(["11111111-1111-4111-8111-111111111111"]);
+  });
+
+  it("supports quoted commas and defaults role to user", () => {
+    const rows = parseUserCsvImport(
+      [
+        "email,firstname,lastname,groups",
+        '"jane@example.com","Jane, Q.","Doe","All Staff"',
+      ].join("\n"),
+    );
+
+    expect(rows[0].firstname).toBe("Jane, Q.");
+    expect(rows[0].role).toBe(User.UserRoleUser);
+    expect(rows[0].groupNames).toEqual(["All Staff"]);
+  });
+
+  it("rejects missing required headers", () => {
+    expect(() =>
+      parseUserCsvImport("email,firstname\njohn@example.com,John"),
+    ).toThrow("missing_header");
+  });
+});
diff --git a/ui/src/util/UserCsvImport.ts b/ui/src/util/UserCsvImport.ts
new file mode 100644
index 00000000..5f0eb007
--- /dev/null
+++ b/ui/src/util/UserCsvImport.ts
@@ -0,0 +1,129 @@
+import User from "@/types/User";
+
+export interface UserCsvImportRow {
+  email: string;
+  firstname: string;
+  lastname: string;
+  role: number;
+  password: string;
+  sendInvitation: boolean;
+  authProviderId: string;
+  organizationId: string;
+  groupIds: string[];
+  groupNames: string[];
+}
+
+function parseCsvLine(line: string): string[] {
+  const result: string[] = [];
+  let current = "";
+  let quoted = false;
+  for (let i = 0; i < line.length; i++) {
+    const ch = line[i];
+    if (ch === '"') {
+      if (quoted && line[i + 1] === '"') {
+        current += '"';
+        i++;
+      } else {
+        quoted = !quoted;
+      }
+    } else if (ch === "," && !quoted) {
+      result.push(current.trim());
+      current = "";
+    } else {
+      current += ch;
+    }
+  }
+  result.push(current.trim());
+  return result;
+}
+
+function splitList(value: string): string[] {
+  if (!value) {
+    return [];
+  }
+  return value
+    .split(";")
+    .map((item) => item.trim())
+    .filter((item) => item !== "");
+}
+
+function parseBool(value: string): boolean {
+  return ["1", "true", "yes", "y"].includes(value.trim().toLowerCase());
+}
+
+function parseRole(value: string): number {
+  const normalized = value.trim().toLowerCase();
+  if (!normalized) {
+    return User.UserRoleUser;
+  }
+  if (/^\d+$/.test(normalized)) {
+    return parseInt(normalized, 10);
+  }
+  if (normalized === "spaceadmin" || normalized === "space_admin") {
+    return User.UserRoleSpaceAdmin;
+  }
+  if (
+    normalized === "orgadmin" ||
+    normalized === "admin" ||
+    normalized === "org_admin"
+  ) {
+    return User.UserRoleOrgAdmin;
+  }
+  if (
+    normalized === "serviceaccountro" ||
+    normalized === "service_account_ro"
+  ) {
+    return User.UserRoleServiceAccountRO;
+  }
+  if (
+    normalized === "serviceaccountrw" ||
+    normalized === "service_account_rw"
+  ) {
+    return User.UserRoleServiceAccountRW;
+  }
+  if (normalized === "superadmin" || normalized === "super_admin") {
+    return User.UserRoleSuperAdmin;
+  }
+  return User.UserRoleUser;
+}
+
+export function parseUserCsvImport(csv: string): UserCsvImportRow[] {
+  const lines = csv
+    .replace(/\r\n/g, "\n")
+    .replace(/\r/g, "\n")
+    .split("\n")
+    .filter((line) => line.trim() !== "");
+  if (lines.length < 2) {
+    throw new Error("missing_rows");
+  }
+  const headers = parseCsvLine(lines[0]).map((header) =>
+    header.trim().toLowerCase(),
+  );
+  const requiredHeaders = ["email", "firstname", "lastname"];
+  requiredHeaders.forEach((header) => {
+    if (!headers.includes(header)) {
+      throw new Error("missing_header");
+    }
+  });
+
+  return lines.slice(1).map((line) => {
+    const values = parseCsvLine(line);
+    const row: { [key: string]: string } = {};
+    headers.forEach((header, idx) => {
+      row[header] = values[idx] || "";
+    });
+    const groupNames = splitList(row.groupnames || row.groups || "");
+    return {
+      email: row.email || "",
+      firstname: row.firstname || "",
+      lastname: row.lastname || "",
+      role: parseRole(row.role || ""),
+      password: row.password || "",
+      sendInvitation: parseBool(row.sendinvitation || ""),
+      authProviderId: row.authproviderid || "",
+      organizationId: row.organizationid || "",
+      groupIds: splitList(row.groupids || ""),
+      groupNames,
+    };
+  });
+}
