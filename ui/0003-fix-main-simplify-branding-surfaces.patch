diff --git a/e2e/tests/branding.spec.ts b/e2e/tests/branding.spec.ts
new file mode 100644
index 00000000..2d856e74
--- /dev/null
+++ b/e2e/tests/branding.spec.ts
@@ -0,0 +1,75 @@
+import { test, expect } from "@playwright/test";
+import { login } from "../util/helper";
+
+const TEST_BRANDING = {
+  websiteName: "Acme Desk",
+  customLogoUrl: "https://example.com/logo.svg",
+};
+
+test.beforeEach(async ({ page }) => {
+  await page.addInitScript(() => {
+    window.localStorage.setItem("mfaEncouragementDismissed", "1");
+  });
+
+  await login(page, "admin@seatsurfing.local", "Sea!surf1ng");
+  await expect(page).toHaveURL(/search\/$/);
+  await expect(
+    page.getByRole("link", { name: "Seatsurfing" }).first(),
+  ).toBeVisible();
+  await page.getByRole("link", { name: "Administration" }).click();
+  await expect(page).toHaveURL(/admin\/dashboard\/$/);
+});
+
+test("branding settings apply to the login page", async ({ page }) => {
+  await page.getByRole("link", { name: "Settings" }).click();
+  await expect(page).toHaveURL(/admin\/settings\/$/);
+
+  const originalWebsiteName = await page.getByLabel("Website name").inputValue();
+  const originalLogoUrl = await page.getByLabel("Custom logo URL").inputValue();
+
+  try {
+    await page.getByLabel("Website name").fill(TEST_BRANDING.websiteName);
+    await page.getByLabel("Custom logo URL").fill(TEST_BRANDING.customLogoUrl);
+    await page.getByRole("button", { name: "Save" }).click();
+    await expect(page.getByText("Record saved.")).toBeVisible();
+
+    await page.getByRole("button", { name: "Logout" }).click();
+    await expect(page).toHaveURL(/login\/$/);
+    await expect(page).toHaveTitle(TEST_BRANDING.websiteName);
+    await expect(
+      page.getByRole("heading", {
+        level: 3,
+        name: TEST_BRANDING.websiteName,
+      }),
+    ).toBeVisible();
+    await expect(page.locator("img.logo")).toHaveCount(1);
+
+    const iconHrefs = await page
+      .locator("link[rel='icon']")
+      .evaluateAll((elements) =>
+        elements.map((element) => element.getAttribute("href") || ""),
+      );
+    expect(iconHrefs.some((href) => href.includes("logo.svg"))).toBe(true);
+  } finally {
+    try {
+      if (page.url().includes("/ui/login/")) {
+        await login(page, "admin@seatsurfing.local", "Sea!surf1ng");
+        await expect(page).toHaveURL(/search\/$/);
+        await expect(
+          page.getByRole("link", { name: TEST_BRANDING.websiteName }).first(),
+        ).toBeVisible();
+        await page.getByRole("link", { name: "Administration" }).click();
+        await expect(page).toHaveURL(/admin\/dashboard\/$/);
+      }
+      await page.getByRole("link", { name: "Settings" }).click();
+      await expect(page).toHaveURL(/admin\/settings\/$/);
+      await page.getByLabel("Website name").fill(originalWebsiteName);
+      await page.getByLabel("Custom logo URL").fill(originalLogoUrl);
+      await page.getByRole("button", { name: "Save" }).click();
+      await expect(page.getByText("Record saved.")).toBeVisible();
+      await page.getByRole("button", { name: "Logout" }).click();
+    } catch {
+      // Best effort restore; avoid masking the original failure.
+    }
+  }
+});
