diff --git a/ui/src/components/BrandMark.tsx b/ui/src/components/BrandMark.tsx
new file mode 100644
index 00000000..3c481b09
--- /dev/null
+++ b/ui/src/components/BrandMark.tsx
@@ -0,0 +1,34 @@
+import React from "react";
+
+interface Props {
+  alt: string;
+  defaultLogoUrl: string;
+  logoUrl?: string | null;
+  brandText?: string | null;
+  imageClassName?: string;
+  textClassName?: string;
+  textTag?: React.ElementType;
+}
+
+export default class BrandMark extends React.Component<Props> {
+  render() {
+    const {
+      alt,
+      defaultLogoUrl,
+      logoUrl,
+      brandText,
+      imageClassName,
+      textClassName,
+      textTag,
+    } = this.props;
+    const text = (brandText ?? "").trim();
+    if (logoUrl) {
+      return <img src={logoUrl} alt={alt} className={imageClassName} />;
+    }
+    if (text) {
+      const Tag = textTag ?? "span";
+      return <Tag className={textClassName}>{text}</Tag>;
+    }
+    return <img src={defaultLogoUrl} alt={alt} className={imageClassName} />;
+  }
+}
