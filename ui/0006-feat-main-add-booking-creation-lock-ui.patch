   hideStats: boolean;
+  weeklyBookingWindowPolicy: boolean;
+  disableBookingCreation: boolean;
 }
 
 interface Props {
@@ -150,6 +152,8 @@ class Settings extends React.Component<Props, State> {
       kioskModeEnabled: false,
       hideReports: false,
       hideStats: false,
+      weeklyBookingWindowPolicy: false,
+      disableBookingCreation: false,
     };
   }
 
@@ -265,6 +269,10 @@ class Settings extends React.Component<Props, State> {
           state.allowOrgDelete = s.value === "1";
         if (s.name === "hide_reports") state.hideReports = s.value === "1";
         if (s.name === "hide_stats") state.hideStats = s.value === "1";
+        if (s.name === "weekly_booking_window_policy")
+          state.weeklyBookingWindowPolicy = s.value === "1";
+        if (s.name === "disable_booking_creation")
+          state.disableBookingCreation = s.value === "1";
       });
 
       const convert = (value: number): number => {
@@ -424,6 +432,14 @@ class Settings extends React.Component<Props, State> {
       ),
       new OrgSettings("hide_reports", this.state.hideReports ? "1" : "0"),
       new OrgSettings("hide_stats", this.state.hideStats ? "1" : "0"),
+      new OrgSettings(
+        "weekly_booking_window_policy",
+        this.state.weeklyBookingWindowPolicy ? "1" : "0",
+      ),
+      new OrgSettings(
+        "disable_booking_creation",
+        this.state.disableBookingCreation ? "1" : "0",
+      ),
     ];
     try {
       await OrgSettings.setAll(payload);
@@ -1118,6 +1134,34 @@ class Settings extends React.Component<Props, State> {
               />
             </Col>
           </Form.Group>
+          <Form.Group as={Row}>
+            <Col sm="6">
+              <Form.Check
+                type="checkbox"
+                id="check-disableBookingCreation"
+                label={this.props.t("disableBookingCreation")}
+                checked={this.state.disableBookingCreation}
+                onChange={(e: any) =>
+                  this.setState({ disableBookingCreation: e.target.checked })
+                }
+              />
+            </Col>
+          </Form.Group>
+          <Form.Group as={Row}>
+            <Col sm="6">
+              <Form.Check
+                type="checkbox"
+                id="check-weeklyBookingWindowPolicy"
+                label={this.props.t("weeklyBookingWindowPolicy")}
+                checked={this.state.weeklyBookingWindowPolicy}
+                onChange={(e: any) =>
+                  this.setState({
+                    weeklyBookingWindowPolicy: e.target.checked,
+                  })
+                }
+              />
+            </Col>
+          </Form.Group>
           <Form.Group as={Row}>
             <Col sm="6">
               <Form.Check
diff --git a/ui/src/pages/search.tsx b/ui/src/pages/search.tsx
index f32b0f97..d00f8eff 100644
--- a/ui/src/pages/search.tsx
+++ b/ui/src/pages/search.tsx
@@ -724,6 +724,13 @@ class Search extends React.Component<Props, State> {
       return;
     }
     if (item.available) {
+      if (RuntimeConfig.INFOS.disableBookingCreation) {
+        this.setState({
+          showError: true,
+          errorText: this.props.t("errorBookingCreationDisabled"),
+        });
+        return;
+      }
       this.setState(
         {
           showConfirm: true,
@@ -947,6 +954,14 @@ class Search extends React.Component<Props, State> {
     if (e) {
       e.preventDefault();
     }
+    if (RuntimeConfig.INFOS.disableBookingCreation) {
+      this.setState({
+        showConfirm: false,
+        showError: true,
+        errorText: this.props.t("errorBookingCreationDisabled"),
+      });
+      return;
+    }
     if (this.state.selectedSpace == null) {
       return;
     }
@@ -2123,6 +2138,14 @@ class Search extends React.Component<Props, State> {
 
             {hint}
 
+            <Alert
+              variant="warning"
+              className="margin-top-10 margin-bottom-0"
+              hidden={!RuntimeConfig.INFOS.disableBookingCreation}
+            >
+              {this.props.t("bookingCreationDisabled")}
+            </Alert>
+
             <Form.Group className="d-flex margin-top-10">
               <div className="me-2">
                 <MapIcon
@@ -2471,6 +2494,7 @@ class Search extends React.Component<Props, State> {
               variant="primary"
               disabled={
                 this.state.confirmingBooking ||
+                RuntimeConfig.INFOS.disableBookingCreation ||
                 (this.state.recurrence.active &&
                   this.state.recurrence.finalNumBookings === 0)
               }
