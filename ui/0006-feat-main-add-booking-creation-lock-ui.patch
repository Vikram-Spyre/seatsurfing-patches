   targetUtilizationHoursPerWeek: number;
+  disableBookingCreation: boolean;
 }
 
 export default class RuntimeConfig {
@@ -110,6 +111,7 @@ export default class RuntimeConfig {
       hasPasskeys: false,
       isPrimaryDomain: false,
       targetUtilizationHoursPerWeek: 0,
+      disableBookingCreation: false,
     };
   };
 
@@ -234,6 +236,8 @@ export default class RuntimeConfig {
             RuntimeConfig.INFOS.hideReports = s.value === "1";
           if (s.name === "hide_stats")
             RuntimeConfig.INFOS.hideStats = s.value === "1";
+          if (s.name === "disable_booking_creation")
+            RuntimeConfig.INFOS.disableBookingCreation = s.value === "1";
           if (s.name === "target_utilization_hours_per_week")
             RuntimeConfig.INFOS.targetUtilizationHoursPerWeek = window.parseInt(
               s.value,
diff --git a/ui/src/pages/admin/bookings/[id].tsx b/ui/src/pages/admin/bookings/[id].tsx
index 83578cbd..ac53bffc 100644
--- a/ui/src/pages/admin/bookings/[id].tsx
+++ b/ui/src/pages/admin/bookings/[id].tsx
@@ -332,6 +332,12 @@ class EditBooking extends React.Component<Props, State> {
       saved: false,
       canSearchHint: "",
     });
+    if (this.isNewBooking && RuntimeConfig.INFOS.disableBookingCreation) {
+      this.setState({
+        canSearchHint: "errorBookingCreationDisabled",
+      });
+      return;
+    }
 
     if (this.dailyBasisBooking) {
       let enter = new Date();
@@ -712,7 +718,13 @@ class EditBooking extends React.Component<Props, State> {
       );
     }
 
-    if (this.state.saved) {
+    if (this.isNewBooking && RuntimeConfig.INFOS.disableBookingCreation) {
+      hint = (
+        <Alert variant="warning">
+          {this.props.t("bookingCreationDisabled")}
+        </Alert>
+      );
+    } else if (this.state.saved) {
       hint = (
         <Alert variant="success">
           {this.props.t(
@@ -740,7 +752,10 @@ class EditBooking extends React.Component<Props, State> {
     );
     const buttonSave = (
       <Button
-        disabled={!(this.state.canSave && this.state.canEdit)}
+        disabled={
+          !(this.state.canSave && this.state.canEdit) ||
+          (this.isNewBooking && RuntimeConfig.INFOS.disableBookingCreation)
+        }
         className="btn-sm"
         variant="outline-secondary"
         type="submit"
diff --git a/ui/src/pages/admin/settings/index.tsx b/ui/src/pages/admin/settings/index.tsx
