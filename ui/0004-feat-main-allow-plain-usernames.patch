diff --git a/e2e/tests/admin-ui.spec.ts b/e2e/tests/admin-ui.spec.ts
index 92898f0a..72e9baab 100644
--- a/e2e/tests/admin-ui.spec.ts
+++ b/e2e/tests/admin-ui.spec.ts
@@ -70,3 +70,46 @@ test("crud location", async ({ page }) => {
   await expect(page).toHaveURL(/locations\/$/);
   await expect(page.getByRole("cell", { name: name })).toHaveCount(0);
 });
+
+test("plain usernames setting relaxes the user form", async ({ page }) => {
+  await page.goto("/ui/admin/settings/");
+  await expect(page).toHaveURL(/admin\/settings\/$/);
+
+  const plainUsernameToggle = page.getByRole("checkbox", {
+    name: "Allow plain usernames",
+  });
+  await plainUsernameToggle.check();
+  await page.getByRole("button", { name: "Save" }).click();
+  await page.getByRole("button", { name: "Reload" }).click();
+
+  const accessToken = await page.evaluate(
+    () => window.localStorage.getItem("accessToken") || "",
+  );
+
+  await page.goto("/ui/admin/users/add/");
+  await expect(page).toHaveURL(/admin\/users\/add\/$/);
+  await expect(page.locator("#email")).toHaveAttribute("type", "text");
+
+  await page.evaluate(() => {
+    window.localStorage.removeItem("accessToken");
+    window.localStorage.removeItem("accessTokenExpiry");
+    window.localStorage.removeItem("logoutUrl");
+    window.localStorage.removeItem("profilePageUrl");
+    window.localStorage.removeItem("refreshToken");
+  });
+
+  await page.goto("/ui/login/");
+  await expect(page).toHaveURL(/login\/$/);
+  await expect(
+    page.locator('form[name="password-login"] input[type="text"]'),
+  ).toHaveCount(1);
+
+  await page.request.put("/setting/allow_plain_username", {
+    headers: {
+      Authorization: `Bearer ${accessToken}`,
+    },
+    data: {
+      value: "0",
+    },
+  });
+});
