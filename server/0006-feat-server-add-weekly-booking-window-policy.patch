+		testWeeklyBookingRequest(now, 2), org.ID, user, now)
+	CheckTestBool(t, true, valid)
+	CheckTestInt(t, 0, code)
+	CheckTestBool(t, false, requiresApproval)
+}
+
+func testWeeklyBookingRequest(now time.Time, weekOffset int) *BookingRequest {
+	dayOffset := (int(now.Weekday()) + 6) % 7
+	weekStart := time.Date(now.Year(), now.Month(), now.Day()-dayOffset, 9, 0, 0, 0, now.Location())
+	enter := weekStart.AddDate(0, 0, weekOffset*7+1)
+	return &BookingRequest{
+		Enter: enter,
+		Leave: enter.Add(8 * time.Hour),
+	}
+}
