+func TestBookingsWeeklyBookingWindowPolicy(t *testing.T) {
+	ClearTestDB()
+	org := CreateTestOrg("test.com")
+	GetSettingsRepository().Set(org.ID, SettingWeeklyBookingWindowPolicy.Name, "1")
+	GetSettingsRepository().Set(org.ID, SettingDefaultTimezone.Name, "UTC")
+	user := CreateTestUserInOrg(org)
+	adminUser := CreateTestUserOrgAdmin(org)
+	router := &BookingRouter{}
+
+	mondayNow := time.Date(2026, 5, 4, 10, 0, 0, 0, time.UTC)
+	wednesdayNow := time.Date(2026, 5, 6, 10, 0, 0, 0, time.UTC)
+	thursdayNow := time.Date(2026, 5, 7, 10, 0, 0, 0, time.UTC)
+
+	valid, code, requiresApproval := router.IsValidWeeklyBookingWindow(
+		testWeeklyBookingRequest(mondayNow, 0), org.ID, user, mondayNow)
+	CheckTestBool(t, true, valid)
+	CheckTestInt(t, 0, code)
+	CheckTestBool(t, false, requiresApproval)
+
+	valid, code, requiresApproval = router.IsValidWeeklyBookingWindow(
+		testWeeklyBookingRequest(mondayNow, 1), org.ID, user, mondayNow)
+	CheckTestBool(t, false, valid)
+	CheckTestInt(t, ResponseCodeBookingTooManyDaysInAdvance, code)
+	CheckTestBool(t, false, requiresApproval)
+
+	valid, code, requiresApproval = router.IsValidWeeklyBookingWindow(
+		testWeeklyBookingRequest(mondayNow, 1), org.ID, adminUser, mondayNow)
+	CheckTestBool(t, true, valid)
+	CheckTestInt(t, 0, code)
+	CheckTestBool(t, true, requiresApproval)
+
+	valid, code, requiresApproval = router.IsValidWeeklyBookingWindow(
+		testWeeklyBookingRequest(wednesdayNow, 2), org.ID, adminUser, wednesdayNow)
+	CheckTestBool(t, true, valid)
+	CheckTestInt(t, 0, code)
+	CheckTestBool(t, true, requiresApproval)
+
+	valid, code, requiresApproval = router.IsValidWeeklyBookingWindow(
+		testWeeklyBookingRequest(thursdayNow, 1), org.ID, user, thursdayNow)
+	CheckTestBool(t, true, valid)
+	CheckTestInt(t, 0, code)
+	CheckTestBool(t, false, requiresApproval)
+
+	valid, code, requiresApproval = router.IsValidWeeklyBookingWindow(
+		testWeeklyBookingRequest(thursdayNow, 2), org.ID, user, thursdayNow)
+	CheckTestBool(t, false, valid)
+	CheckTestInt(t, ResponseCodeBookingTooManyDaysInAdvance, code)
+	CheckTestBool(t, false, requiresApproval)
+
+	valid, code, requiresApproval = router.IsValidWeeklyBookingWindow(
+		testWeeklyBookingRequest(thursdayNow, 2), org.ID, adminUser, thursdayNow)
+	CheckTestBool(t, false, valid)
+	CheckTestInt(t, ResponseCodeBookingTooManyDaysInAdvance, code)
+	CheckTestBool(t, false, requiresApproval)
+}
