+func (router *BookingRouter) IsValidWeeklyBookingWindow(m *BookingRequest, orgID string, user *User, now time.Time) (bool, int, bool) {
+	enabled, _ := GetSettingsRepository().GetBool(orgID, SettingWeeklyBookingWindowPolicy.Name)
+	if !enabled {
+		return true, 0, false
+	}
+
+	weekOffset, weekday, ok := router.getWeeklyBookingWindowOffset(m.Enter, orgID, now)
+	if !ok {
+		return false, ResponseCodeBookingTooManyDaysInAdvance, false
+	}
+	isEarlyWeek := weekday >= time.Monday && weekday <= time.Wednesday
+	isSpaceAdmin := CanSpaceAdminOrg(user, orgID)
+
+	if weekOffset == 0 {
+		return true, 0, false
+	}
+	if isEarlyWeek {
+		if isSpaceAdmin && weekOffset <= 2 {
+			return true, 0, true
+		}
+		return false, ResponseCodeBookingTooManyDaysInAdvance, false
+	}
+	if weekOffset == 1 {
+		return true, 0, false
+	}
+	return false, ResponseCodeBookingTooManyDaysInAdvance, false
+}
+
+func (router *BookingRouter) isBookingApprovedOnCreate(spaceRequiresApproval bool, m *BookingRequest, orgID string, user *User) bool {
+	weeklyPolicyEnabled, _ := GetSettingsRepository().GetBool(orgID, SettingWeeklyBookingWindowPolicy.Name)
+	if weeklyPolicyEnabled {
+		valid, _, requiresApproval := router.IsValidWeeklyBookingWindow(m, orgID, user, time.Now().UTC())
+		return valid && !requiresApproval
+	}
+	return !spaceRequiresApproval
+}
+
+func (router *BookingRouter) getWeeklyBookingWindowOffset(enter time.Time, orgID string, now time.Time) (int, time.Weekday, bool) {
+	tz, err := GetSettingsRepository().Get(orgID, SettingDefaultTimezone.Name)
+	if err != nil || tz == "" {
+		tz = "UTC"
+	}
+	loc, err := time.LoadLocation(tz)
+	if err != nil {
+		loc = time.UTC
+	}
+
+	nowLocal := now.In(loc)
+	enterLocal := enter.In(loc)
+	nowWeekStart := router.getWeekStart(nowLocal)
+	enterWeekStart := router.getWeekStart(enterLocal)
+	diffHours := enterWeekStart.Sub(nowWeekStart).Hours()
+	weekOffset := int(math.Floor(diffHours / (24 * 7)))
+	if weekOffset < 0 {
+		return weekOffset, nowLocal.Weekday(), false
+	}
+	return weekOffset, nowLocal.Weekday(), true
+}
+
+func (router *BookingRouter) getWeekStart(t time.Time) time.Time {
+	dayOffset := (int(t.Weekday()) + 6) % 7
+	year, month, day := t.Date()
+	return time.Date(year, month, day-dayOffset, 0, 0, 0, 0, t.Location())
+}
+
