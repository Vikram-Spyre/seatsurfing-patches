diff --git a/server/router/branding.go b/server/router/branding.go
new file mode 100644
index 00000000..cfd60cd0
--- /dev/null
+++ b/server/router/branding.go
@@ -0,0 +1,23 @@
+package router
+
+import . "github.com/seatsurfing/seatsurfing/server/repository"
+
+type BrandingInfo struct {
+	WebsiteName string
+	LogoURL     string
+}
+
+func getOrganizationBranding(organizationID string, organizationName string) BrandingInfo {
+	branding := BrandingInfo{
+		WebsiteName: organizationName,
+	}
+
+	if value, err := GetSettingsRepository().Get(organizationID, SettingWebsiteName.Name); err == nil && value != "" {
+		branding.WebsiteName = value
+	}
+	if value, err := GetSettingsRepository().Get(organizationID, SettingCustomLogoUrl.Name); err == nil {
+		branding.LogoURL = value
+	}
+
+	return branding
+}
