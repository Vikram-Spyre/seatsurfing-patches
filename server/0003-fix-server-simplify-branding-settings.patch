+func TestAuthGetOrgDetailsBranding(t *testing.T) {
+	ClearTestDB()
+	org := CreateTestOrg("test.com")
+	GetSettingsRepository().Set(org.ID, SettingWebsiteName.Name, "Acme Desk")
+	GetSettingsRepository().Set(org.ID, SettingCustomLogoUrl.Name, "https://example.com/logo.svg")
+
+	req := NewHTTPRequest("GET", "/auth/org/test.com", "", nil)
+	res := ExecuteTestRequest(req)
+	CheckTestResponseCode(t, http.StatusOK, res.Code)
+
+	var resBody *AuthPreflightResponse
+	json.Unmarshal(res.Body.Bytes(), &resBody)
+	CheckTestIsNil(t, resBody)
+	CheckTestString(t, "Acme Desk", resBody.Organization.WebsiteName)
+	CheckTestString(t, "https://example.com/logo.svg", resBody.Organization.LogoURL)
+	CheckTestString(t, "Test Org", resBody.Organization.Name)
+}
