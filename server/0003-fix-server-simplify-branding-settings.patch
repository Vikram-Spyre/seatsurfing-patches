+func TestSettingsBrandingCRUD(t *testing.T) {
+	ClearTestDB()
+	org := CreateTestOrg("test.com")
+	user := CreateTestUserOrgAdmin(org)
+	loginResponse := LoginTestUser(user.ID)
+
+	payload := `[{"name": "website_name", "value": "Acme Desk"},{"name": "custom_logo_url", "value": "https://example.com/logo.svg"}]`
+	req := NewHTTPRequest("PUT", "/setting/", loginResponse.UserID, bytes.NewBufferString(payload))
+	res := ExecuteTestRequest(req)
+	CheckTestResponseCode(t, http.StatusNoContent, res.Code)
+
+	req = NewHTTPRequest("GET", "/setting/website_name", loginResponse.UserID, nil)
+	res = ExecuteTestRequest(req)
+	CheckTestResponseCode(t, http.StatusOK, res.Code)
+	var websiteName string
+	json.Unmarshal(res.Body.Bytes(), &websiteName)
+	CheckTestString(t, "Acme Desk", websiteName)
+
+	req = NewHTTPRequest("GET", "/setting/", loginResponse.UserID, nil)
+	res = ExecuteTestRequest(req)
+	CheckTestResponseCode(t, http.StatusOK, res.Code)
+	var resBody []GetSettingsResponse
+	json.Unmarshal(res.Body.Bytes(), &resBody)
+	resMap := settingsResponseMap(resBody)
+	CheckTestString(t, "Acme Desk", resMap[SettingWebsiteName.Name])
+	CheckTestString(t, "https://example.com/logo.svg", resMap[SettingCustomLogoUrl.Name])
+
+	payload = `{"value": "notaurl"}`
+	req = NewHTTPRequest("PUT", "/setting/"+SettingCustomLogoUrl.Name, loginResponse.UserID, bytes.NewBufferString(payload))
+	res = ExecuteTestRequest(req)
+	CheckTestResponseCode(t, http.StatusBadRequest, res.Code)
 }
 
