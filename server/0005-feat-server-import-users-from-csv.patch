+func (router *UserRouter) importUsers(w http.ResponseWriter, r *http.Request) {
+	user := GetRequestUser(r)
+	if !CanAdminOrg(user, user.OrganizationID) {
 		SendForbidden(w)
 		return
 	}
-	targetOrgID := user.OrganizationID
-	if m.OrganizationID != "" && GetUserRepository().IsSuperAdmin(user) {
-		targetOrgID = m.OrganizationID
+	var m ImportUsersRequest
+	if UnmarshalValidateBody(r, &m) != nil {
+		SendBadRequest(w)
+		return
 	}
+
+	res := &ImportUsersResponse{}
+	for idx, importUser := range m.Users {
+		row := idx + 2
+		result := &ImportUserResult{
+			Row:   row,
+			Email: importUser.Email,
+		}
+		targetOrganizationID := router.getCreateUserTargetOrganizationID(user, &importUser.CreateUserRequest)
+		groups, errText := router.resolveImportUserGroups(targetOrganizationID, importUser)
+		if errText != "" {
+			result.Status = "failed"
+			result.Error = errText
+			res.Failed++
+			res.Results = append(res.Results, result)
+			continue
+		}
+
+		createdUser, statusCode, appCode := router.createUser(user, &importUser.CreateUserRequest)
+		if statusCode != http.StatusCreated {
+			result.Status = "failed"
+			result.Error = router.createUserImportError(statusCode, appCode)
+			res.Failed++
+			res.Results = append(res.Results, result)
+			continue
+		}
+		membershipFailed := false
+		for _, group := range groups {
+			if err := GetGroupRepository().AddMembers(group, []string{createdUser.ID}); err != nil {
+				log.Println(err)
+				result.Status = "failed"
+				result.Error = "group_membership_failed"
+				res.Failed++
+				res.Results = append(res.Results, result)
+				membershipFailed = true
+				break
+			}
+		}
+		if membershipFailed {
+			continue
+		}
+		result.ID = createdUser.ID
+		result.Status = "created"
+		res.Created++
+		res.Results = append(res.Results, result)
+	}
+
+	SendJSON(w, res)
+}
