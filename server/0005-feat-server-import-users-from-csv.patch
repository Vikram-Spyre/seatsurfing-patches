+func (router *UserRouter) resolveImportUserGroups(organizationID string, m *ImportUserRequest) ([]*Group, string) {
+	groupsByID := map[string]*Group{}
+	for _, groupID := range m.GroupIDs {
+		if _, exists := groupsByID[groupID]; exists {
+			continue
+		}
+		group, err := GetGroupRepository().GetOne(groupID)
+		if err != nil || group.OrganizationID != organizationID {
+			return nil, "invalid_group"
+		}
+		groupsByID[group.ID] = group
+	}
+	for _, groupName := range m.GroupNames {
+		group, err := GetGroupRepository().GetByName(organizationID, strings.TrimSpace(groupName))
+		if err != nil {
+			return nil, "invalid_group"
+		}
+		groupsByID[group.ID] = group
+	}
+	groups := []*Group{}
+	for _, group := range groupsByID {
+		groups = append(groups, group)
+	}
+	return groups, ""
+}
