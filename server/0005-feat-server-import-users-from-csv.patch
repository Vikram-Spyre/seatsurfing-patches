+func (router *UserRouter) sendCreateUserError(w http.ResponseWriter, statusCode int, appCode int) {
+	if statusCode == http.StatusBadRequest {
+		SendBadRequest(w)
+		return
+	}
+	if statusCode == http.StatusForbidden {
+		SendForbidden(w)
+		return
+	}
+	if statusCode == http.StatusPaymentRequired {
+		SendPaymentRequired(w)
+		return
+	}
+	if statusCode == http.StatusConflict {
+		if appCode != 0 {
+			SendAlreadyExistsCode(w, appCode)
 			return
 		}
+		SendAlreadyExists(w)
+		return
 	}
+	SendInternalServerError(w)
+}
 
-	SendCreated(w, e.ID)
+func (router *UserRouter) createUserImportError(statusCode int, appCode int) string {
+	if statusCode == http.StatusConflict && appCode == ResponseCodeUserAlreadyExists {
+		return "user_already_exists"
+	}
+	if statusCode == http.StatusBadRequest {
+		return "invalid_user"
+	}
+	if statusCode == http.StatusForbidden {
+		return "forbidden"
+	}
+	if statusCode == http.StatusPaymentRequired {
+		return "user_limit_exceeded"
+	}
+	return "internal_error"
 }
 
