+	payload = "{\"email\": \"" + updatedUsername + "\", \"firstname\": \"Jane\", \"lastname\": \"Doe\", \"password\": \"\", \"role\": " + strconv.Itoa(int(UserRoleSpaceAdmin)) + "}"
